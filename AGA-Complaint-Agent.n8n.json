    "ตั้งเวลา 3 รอบ/วัน": {
      "main": [
        [ { "node": "อ่านงานค้าง (Sheet)", "type": "main", "index": 0 } ]
      ]
    },
    "อ่านงานค้าง (Sheet)": {
