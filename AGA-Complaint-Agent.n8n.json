        [ { "node": "Gemini AI วิเคราะห์", "type": "main", "index": 0 } ]
      ]
    },
    "Gemini AI วิเคราะห์": {
      "main": [
        [ { "node": "บันทึกงานใหม่ (Sheet)", "type": "main", "index": 0 } ]
      ]
    },
    "บันทึกงานใหม่ (Sheet)": {
